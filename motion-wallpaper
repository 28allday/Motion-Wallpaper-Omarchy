#!/usr/bin/env bash
# ==============================================================================
# motion-wallpaper — command-line control for the omarchy-shell video-wallpaper
# plugin (nosignal.motion-wallpaper) on Omarchy 4 (Quickshell).
#
# The interactive UI now lives in the shell itself: a bar widget + dropdown
# panel (click the ◐/film icon in the bar). This CLI is the scriptable path —
# for keybinds, SSH, and automation. It is a thin wrapper over the shell IPC:
#   qs -p /usr/share/omarchy/shell ipc call motion-wallpaper <fn> [args]
#
# Commands:
#   status  (default)  Print current state.
#   play <file>        Set + start a video (enables + persists).
#   stop               Stop; the static wallpaper shows through.
#   toggle             Flip on/off (handy for a keybind).
#   pause | resume     Pause/resume without tearing the surface down.
#   screen <name|all>  Play on a specific output, or all of them.
#   autopause <on|off> Pause the video when a fullscreen window covers it.
#
# State (owned by the plugin): ~/.local/state/motion-wallpaper/state.json
# Log: ~/.cache/motion-wallpaper.log
# ==============================================================================

set -euo pipefail

APP_NAME="Motion Wallpaper"
QS_SHELL="/usr/share/omarchy/shell"
LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
LOG_FILE="$LOG_DIR/motion-wallpaper.log"
mkdir -p "$LOG_DIR"

TXT_ERR_NO_SHELL="omarchy-shell (Quickshell) isn't running. Start your Omarchy session first."
TXT_ERR_NO_PLUGIN="The motion-wallpaper plugin isn't loaded. Run the installer (wallpaper.sh)."

err() { echo "motion-wallpaper: $*" >&2; }

require_cmd() {
  local c
  for c in "$@"; do command -v "$c" >/dev/null 2>&1 || { err "'$c' is not installed."; exit 1; }; done
}

shell_running() { pgrep -f "quickshell.*$QS_SHELL" >/dev/null 2>&1; }
plugin_loaded() { qs -p "$QS_SHELL" ipc show 2>/dev/null | grep -qx "target motion-wallpaper"; }

require_plugin() {
  shell_running  || { err "$TXT_ERR_NO_SHELL";  exit 1; }
  plugin_loaded  || { err "$TXT_ERR_NO_PLUGIN"; exit 1; }
}

ipc() { qs -p "$QS_SHELL" ipc call motion-wallpaper "$@" 2>>"$LOG_FILE"; }

# Derive a single human state word from a status JSON payload on stdin.
state_word() {
  local j enabled paused exists video
  j="$(cat)"
  enabled="$(jq -r '.enabled // false' <<<"$j")"
  paused="$(jq -r '.manualPaused // false' <<<"$j")"
  exists="$(jq -r '.videoFileExists // false' <<<"$j")"
  video="$(jq -r '.videoPath // ""' <<<"$j")"
  if [ "$enabled" != "true" ]; then echo stopped; return; fi
  if [ -z "$video" ]; then echo "no video set"; return; fi
  if [ "$exists" != "true" ]; then echo "file missing"; return; fi
  if [ "$paused" = "true" ]; then echo paused; return; fi
  echo playing
}

cmd_status() {
  require_cmd jq
  require_plugin
  local j; j="$(ipc status 2>/dev/null || echo '{}')"
  local video output pause
  video="$(jq -r '.videoPath // ""' <<<"$j")"
  output="$(jq -r '.output // "all"' <<<"$j")"
  pause="$(jq -r '.pauseOnFullscreen // false' <<<"$j")"
  [ "$output" = "all" ] && output="all screens"
  printf 'status:     %s\n' "$(state_word <<<"$j")"
  printf 'video:      %s\n' "${video:-(none)}"
  printf 'screen:     %s\n' "$output"
  printf 'auto-pause: %s\n' "$([ "$pause" = "true" ] && echo on || echo off)"
}

cmd_play() {
  require_plugin
  local f="${1:-}"
  [ -n "$f" ] || { err "usage: motion-wallpaper play <file>"; exit 1; }
  [ -f "$f" ] || { err "file not found: $f"; exit 1; }
  ipc play "$(readlink -f "$f")" >/dev/null
}

cmd_screen() {
  require_plugin
  local s="${1:-}"
  [ -n "$s" ] || { err "usage: motion-wallpaper screen <monitor-name|all>"; exit 1; }
  ipc setOutput "$s" >/dev/null
}

cmd_autopause() {
  require_plugin
  case "${1:-}" in
    on|true)   ipc setPauseOnFullscreen true  >/dev/null ;;
    off|false) ipc setPauseOnFullscreen false >/dev/null ;;
    *) err "usage: motion-wallpaper autopause <on|off>"; exit 1 ;;
  esac
}

case "${1:-status}" in
  status|"") cmd_status ;;
  play)      shift; cmd_play "${1:-}" ;;
  stop)      require_plugin; ipc stop   >/dev/null ;;
  toggle)    require_plugin; ipc toggle >/dev/null ;;
  pause)     require_plugin; ipc pause  >/dev/null ;;
  resume)    require_plugin; ipc resume >/dev/null ;;
  screen)    shift; cmd_screen "${1:-}" ;;
  autopause) shift; cmd_autopause "${1:-}" ;;
  -h|--help)
    cat <<USAGE
$APP_NAME — control the omarchy-shell video wallpaper plugin.
The interactive UI is the bar widget + panel (click the film icon in the bar).

Usage: ${0##*/} [command]
  status              Print current state (default).
  play <file>         Set and start a video file.
  stop                Stop; static wallpaper shows through.
  toggle              Flip on/off (good for a keybind).
  pause | resume      Pause/resume playback.
  screen <name|all>   Play on a specific output, or all.
  autopause <on|off>  Pause video under fullscreen windows.

A playing wallpaper resumes automatically after reboot — no autostart step.
USAGE
    ;;
  *) err "unknown command: $1 (try --help)"; exit 1 ;;
esac
